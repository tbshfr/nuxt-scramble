{
  "name": "nuxt-scramble",
  "version": "0.2.2",
  "description": "Nuxt module that obfuscates emails, phone numbers and custom text in HTML to make scraping harder",
  "repository": "tbshfr/nuxt-scramble",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "pnpm run dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "release": "pnpm run lint && pnpm run test && pnpm run test:e2e && changelogen --release --push",
    "release:major": "pnpm run lint && pnpm run test && pnpm run test:e2e && changelogen --release --clean --push --major",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:e2e": "playwright test",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.4"
  },
  "devDependencies": {
    "@nuxt/devtools": "^3.1.1",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.4",
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.2",
    "@vue/eslint-config-prettier": "^10.2.0",
    "changelogen": "^0.6.2",
    "eslint": "^9.39.4",
    "nuxt": "^4.4.4",
    "typescript": "~5.9.3",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.8"
  },
  "packageManager": "pnpm@11.1.2"
}
